{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
  },
  "lsp": {
    "solidity": {
      "extensions": [".sol"],
      "command": [
        "~/.local/share/nvim/mason/bin/nomicfoundation-solidity-language-server",
        "--stdio",
      ],
    },
  },
  "agent": {
    "code-reviewer": {
      "description": "Code review that should be ran before pushing code",
      "mode": "all",
      "temperature": 0.3,
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow",
          "mise.local.toml": "deny",
        },
        "grep": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow",
          "mise.local.toml": "deny",
        },
        "edit": "deny",
        "webfetch": "deny",
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git remote*": "allow",
          "git status*": "allow",
          "git branch*": "allow",
          "git log*": "allow",
          "git rev-parse*": "allow",
          "grep *": "allow",
          "gh api *": "allow"
        }
      }
    }
  }
}
